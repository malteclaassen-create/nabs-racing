# Dependencies
node_modules/

# Build output
dist/

# Environment / secrets
.env
.env.*
!.env.example
*.local

# Local SQLite database (generated by `npm run seed`)
*.db
*.db-journal
# WAL-mode side files (created once journal_mode=WAL is set in lib/prisma.js)
*.db-wal
*.db-shm
backend/prisma/dev.db

# User uploads (driver profile pictures, served at /api/uploads)
backend/uploads/

# Self-hosted downloads (large AC files placed on the server by the admin)
backend/downloads/*
!backend/downloads/.gitkeep

# Archived raw AC result JSONs (kept so telemetry can be recomputed later).
# Runtime data under DATA_DIR — regeneratable from imports/backfill, not source.
backend/results-archive/

# Logs
*.log
npm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
.idea/


# Raw source material (screenshots etc.) for rebuilding archive seasons - not site code
archive-material/

# Local dev tooling config (not part of the site)
__pycache__/
