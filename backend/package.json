{
  "name": "nabs-racing-backend",
  "version": "1.0.0",
  "description": "NABS Racing League Season 7 - REST API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "start:prod": "prisma migrate deploy && node src/index.js",
    "postinstall": "prisma generate",
    "seed": "node prisma/seed.js",
    "import:archive": "node scripts/import-archive-season.mjs",
    "archive:inventory": "node scripts/archive-emperor-inventory.mjs",
    "migrate": "prisma migrate dev --name init",
    "generate": "prisma generate",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.18",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "vitest": "^2.1.8"
  }
}
