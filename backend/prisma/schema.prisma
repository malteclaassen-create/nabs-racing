// NABS Racing League - Season 7
// Prisma schema. PostgreSQL.
//
// NOTE: Two additions vs. the original spec schema, required for correctness:
//   * RaceResult.points  -> historical R1-R8 data only gives us per-driver
//                           POINTS (not finishing positions), so we must be
//                           able to store points directly. For R9 (and future
//                           imports) points are computed from `position` and
//                           this column is left null / recomputed.
//   * ConstructorRaceScore -> for R1-R8 the per-race constructor points are
//                           NOT derivable from the two listed tier drivers
//                           (reserve subs contributed points). We therefore
//                           store the verified per-race constructor totals and
//                           sum them server-side. For R9+ these rows are
//                           generated by the points calculator at import time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A league season (e.g. Season 7 = F1 2007). Each season is a self-contained
// world: its own teams, drivers and races. Exactly one season is `isActive`,
// which is what the public site shows by default; older seasons stay readable
// as an archive via the season switcher.
model Season {
  id        String   @id @default(cuid())
  number    Int      @unique
  name      String // display label, e.g. "Season 7"
  game      String? // e.g. "F1 2007 · Assetto Corsa"
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())

  teams   Team[]
  drivers Driver[]
  races   Race[]
}

model Team {
  id      String @id
  name    String
  tier    Int // 0=Reserve, 1=Tier1, 2=Tier2
  color   String // HEX
  // Optional logo image path (e.g. "/teams/ferrari.png"), uploaded via admin.
  logoUrl String?

  // Which season this team belongs to. Nullable for backward-compatibility with
  // the pre-season-model data; backfilled to Season 7 and always set going forward.
  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id])

  drivers          Driver[]
  results          RaceResult[]
  constructorScores ConstructorRaceScore[]
  seatOffers       SeatOffer[]
}

model Driver {
  id          String   @id
  name        String
  discordName String
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  // Which season this driver entry belongs to (backfilled to Season 7).
  seasonId    String?
  season      Season?  @relation(fields: [seasonId], references: [id])
  tier        Int // 0/1/2
  isActive    Boolean  @default(true)
  // Linked Discord account id (set on first Discord login) -> forgery-proof RSVP
  discordUserId String? @unique
  // Profile picture: admin-set URL takes priority, else the Discord avatar URL
  // captured on first Discord login (see discordAuth.js).
  photoUrl      String?
  discordAvatar String?
  // Self-selected nationality (ISO 3166-1 alpha-2, lowercase), set by the driver
  // on their profile page after Discord login. Takes priority over the static
  // roster baseline in the frontend's driverCountries.js.
  country       String?
  // Self-service profile extras, edited by the driver on /profile after Discord
  // login: a short "about me" blurb and an optional racing number (0-999).
  bio           String?
  number        Int?
  // Per-driver social links, edited on /profile. JSON object keyed by platform
  // (twitch/youtube/instagram/tiktok/x) -> full URL; null/absent when unset.
  socials       String?
  results     RaceResult[]
  rsvps       RaceRsvp[]
  // Driver Market: seats this driver has offered, seats this (reserve) driver
  // was chosen to fill, and the offers this (reserve) driver is interested in.
  seatOffersOffered SeatOffer[]    @relation("SeatOfferedBy")
  seatOffersFilled  SeatOffer[]    @relation("SeatFilledBy")
  seatInterests     SeatInterest[]
  createdAt   DateTime @default(now())
}

model Race {
  id          String       @id @default(cuid())
  // Round number within its season (unique per season, so each season can start
  // again at round 1). Null for non-championship special events.
  number      Int?
  // Whether this is a non-championship special event (shown on the calendar but
  // not scored / not part of the round numbering).
  isSpecialEvent Boolean   @default(false)
  // Which season this race belongs to (backfilled to Season 7).
  seasonId    String?
  season      Season?      @relation(fields: [seasonId], references: [id])
  track       String
  date        DateTime?
  isCompleted Boolean      @default(false)
  capacity    Int          @default(40) // grid size (Apollo "Accepted (n/40)")
  info        String? // optional event details (sessions, streamer, …)
  // Discord webhook message id for the live RSVP/event post (Apollo-style).
  discordMessageId String?
  results     RaceResult[]
  constructorScores ConstructorRaceScore[]
  rsvps       RaceRsvp[]
  seatOffers  SeatOffer[]

  @@unique([seasonId, number])
}

// Per-race attendance (replaces Apollo): a driver's status for an upcoming race.
model RaceRsvp {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  status    String // ACCEPTED / DECLINED / TENTATIVE
  updatedAt DateTime @updatedAt

  @@unique([raceId, driverId])
}

// ---------------------------------------------------------------------------
// Driver Market. A full-time driver who can't attend offers their seat for an
// upcoming race; reserve drivers express interest; the offering driver (or an
// admin) picks who fills it. The confirmed reserve pre-fills the result import
// (subForTeam) and shows in the per-team race lineup. Interest stays open even
// after a seat is filled, so an admin can swap in a different reserve later.
model SeatOffer {
  id         String   @id @default(cuid())
  raceId     String
  race       Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  // The full-time driver giving up their seat, and the team/seat on offer (the
  // offering driver's own team at the time of the offer).
  driverId   String
  driver     Driver   @relation("SeatOfferedBy", fields: [driverId], references: [id])
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  status     String   @default("OPEN") // OPEN / FILLED / CANCELLED
  // The reserve chosen to fill the seat (null while OPEN / CANCELLED).
  filledById String?
  filledBy   Driver?  @relation("SeatFilledBy", fields: [filledById], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  interests  SeatInterest[]

  @@unique([raceId, driverId])
}

model SeatInterest {
  id        String    @id @default(cuid())
  offerId   String
  offer     SeatOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([offerId, driverId])
}

model RaceResult {
  id               String  @id @default(cuid())
  raceId           String
  race             Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driverId         String
  driver           Driver  @relation(fields: [driverId], references: [id])
  position         Int? // null = DNS / historical points-only result
  points           Int? // explicit points (historical). null => compute from position+status
  status           String  @default("FINISHED") // FINISHED/DNS/DNF/DSQ
  subForTeamId     String? // Reserve drives for this team
  subForTeam       Team?   @relation(fields: [subForTeamId], references: [id])
  // DEPRECATED: the old "penalty in places" model. Replaced by penaltySeconds
  // (time penalties). Kept as an unused column so the migration stays additive;
  // nothing reads or writes it any more.
  penaltyPositions Int     @default(0)
  // Steward time penalty in SECONDS (e.g. 5 or 10), added to totalTimeMs and the
  // field re-sorted by adjusted total time. 0 = none. Needs totalTimeMs to apply.
  penaltySeconds   Int     @default(0)
  // Real finishing-order metadata from the AC race JSON (for driver profiles).
  // grid/bestLap only enrich profiles; totalTimeMs is also used to apply time
  // penalties (re-sort the field by race time + penalty seconds).
  grid             Int? // starting grid position
  bestLapMs        Int? // best lap in milliseconds
  totalTimeMs      Int? // total race time in milliseconds (from AC `TotalTime`)
  // Car-to-car contacts this driver's car registered in the race (from the AC
  // result `Events`, COLLISION_WITH_CAR above a minimum impact speed). Feeds the
  // "Awareness/cleanliness" driver rating. null = not yet imported for this round.
  contacts         Int?

  @@unique([raceId, driverId])
}

// Per-race constructor totals (verified historical + computed at import time)
model ConstructorRaceScore {
  id     String @id @default(cuid())
  raceId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])
  tier   Int // 1 or 2 (which standings table this belongs to)
  points Int    @default(0)

  @@unique([raceId, teamId, tier])
}

model DriverSignup {
  id            String   @id @default(cuid())
  discordName   String
  preferredTeam String?
  experience    String?
  notes         String?
  status        String   @default("PENDING") // PENDING/APPROVED/REJECTED
  createdAt     DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}
