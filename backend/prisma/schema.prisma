// NABS Racing League - Season 7
// Prisma schema. PostgreSQL.
//
// NOTE: Two additions vs. the original spec schema, required for correctness:
//   * RaceResult.points  -> historical R1-R8 data only gives us per-driver
//                           POINTS (not finishing positions), so we must be
//                           able to store points directly. For R9 (and future
//                           imports) points are computed from `position` and
//                           this column is left null / recomputed.
//   * ConstructorRaceScore -> for R1-R8 the per-race constructor points are
//                           NOT derivable from the two listed tier drivers
//                           (reserve subs contributed points). We therefore
//                           store the verified per-race constructor totals and
//                           sum them server-side. For R9+ these rows are
//                           generated by the points calculator at import time.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A racing series (migration series_model). The level ABOVE Season: the league
// can host several independent championships (e.g. the Friday F1 league and a
// Sunday GT series) in ONE deployment. Each series has its own seasons (and
// through them teams/drivers/races/standings); Discord login, members area,
// downloads and the bot stay global. Exactly one series is `isActive` — the
// primary one "/" redirects to. The `slug` is the URL identity (/s/<slug>/…)
// and stays STABLE after creation (renames only touch `name`), so shared and
// bookmarked links never break. Like PersonLink/Download, this table is
// managed via raw SQL (the running dev server locks the generated Prisma
// client on Windows) — see backend/src/lib/series.js, kept in sync by hand.
model Series {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  game        String?
  description String?
  order       Int      @default(0) // position in the series switcher
  isActive    Boolean  @default(false) // the primary series ("/" target)
  isPublic    Boolean  @default(true) // hidden from the public until published
  // Admin-picked accent colour (migration series_accent_color), hex like
  // "#6de0fc". null = the default NABS pink. The frontend derives a readable
  // darker variant for light-mode text from this single value — see
  // frontend/src/utils/seriesColor.js. Deliberately NOT baked into any CSS
  // rule keyed by slug: a hardcoded [data-series="..."] selector broke the
  // moment production's real slug differed from the one tested locally.
  accentColor String?
  // Admin-uploaded dark-mode logo mark (migration series_logo), e.g.
  // "/api/uploads/series/<id>.png?v=<ts>". null = the shared default
  // logo-dark.png. Light mode always uses the shared logo-light.png (a plain
  // black mark reads fine regardless of series colour, so it has no
  // override). Same "upload via admin, not a slug-named file" fix as
  // accentColor above — a /logo-dark-<slug>.png convention has the identical
  // failure mode if the real slug ever differs from what was tested locally.
  logoDarkUrl String?
  createdAt   DateTime @default(now())

  seasons Season[]
}

// A league season (e.g. Season 7 = F1 2007). Each season is a self-contained
// world: its own teams, drivers and races. Per SERIES exactly one season is
// `isActive`, which is what the public site shows by default; older seasons
// stay readable as an archive via the season switcher.
model Season {
  id        String   @id @default(cuid())
  // Round number within its series (unique per series since the series model —
  // was globally unique before, migration series_model relaxed it so a second
  // series can start at Season 1 again).
  number    Int
  name      String // display label, e.g. "Season 7"
  // Which series this season belongs to (migration series_model). Nullable for
  // the backfill; ensureAppSchema assigns stragglers to the default series on
  // every boot, so effectively always set. Raw-SQL column like teamDropWorst.
  seriesId  String?
  series    Series?  @relation(fields: [seriesId], references: [id])
  game      String? // e.g. "F1 2007 · Assetto Corsa"
  isActive  Boolean  @default(false)
  // Scoring rules, admin-editable per season (migration season_scoring):
  //   dropWorst   = how many of a competitor's lowest-scoring rounds are dropped
  //                 from season totals (0 = every round counts).
  //   pointsTable = JSON array of points for P1..Pn (e.g. "[35,30,25,...]");
  //                 null = the league default table in pointsCalculator.js.
  dropWorst   Int     @default(3)
  pointsTable String?
  // Official final standings for archived seasons, imported straight from the
  // old league sheets/Discord posts (migration season_final_standings). JSON:
  //   { "drivers":[{driverId,points}], "teams":[{teamId,points}] }
  // When set, these totals & their array order are AUTHORITATIVE: the standings
  // service uses them verbatim instead of the values it would compute from the
  // race results (per-race data, if any, still renders). null = compute as usual.
  finalStandings String?
  // Team-level drop rule (migration team_drop_worst). null = legacy behaviour
  // (teams inherit each driver's own dropped rounds); 0 = no team drop; N = drop
  // the N lowest single-driver round contributions from each team's total.
  // Managed via raw SQL (ensureAppSchema) so it's writable with the dev server up.
  teamDropWorst Int?
  // How teamDropWorst counts (migration team_drop_mode). null/'results' = the N
  // lowest single-driver round scores; 'rounds' = the N lowest whole team round
  // totals, exactly how the league's official sheet computes its standings.
  // Managed via raw SQL (ensureAppSchema) so it's writable with the dev server up.
  teamDropMode String?
  // Season visibility (migration season_privacy). Existing rows default public;
  // new seasons are created private and hidden from every public read until the
  // admin publishes them. An active season is always forced public.
  isPublic  Boolean  @default(true)
  // "Coming up" announcement (migration season_announced): when ON, an upcoming
  // season advertises itself in the Home/Welcome teaser strip even while it is
  // still PRIVATE (name, game, opener + car picture only — nothing else leaks).
  // Toggled on the admin Seasons tab; managed via raw SQL (ensureAppSchema).
  isAnnounced Boolean @default(false)
  // Admin-uploaded hero photo for the Home/Welcome main card (migration
  // season_hero_image), e.g. "/api/uploads/seasons/<id>.jpg?v=<ts>". null =
  // fall back to the static /heroes/s<number>.jpg drop-in convention, then the
  // shared /hero.jpg (see frontend/src/utils/heroImage.js). Managed via raw
  // SQL (ensureAppSchema) so it's writable with the dev server up.
  heroImageUrl String?
  createdAt DateTime @default(now())

  teams   Team[]
  drivers Driver[]
  races   Race[]

  @@unique([seriesId, number])
}

model Team {
  id      String @id
  name    String
  tier    Int // 0=Reserve, 1=Tier1, 2=Tier2
  color   String // HEX
  // Optional logo image path (e.g. "/teams/ferrari.png"), uploaded via admin.
  logoUrl String?

  // Which season this team belongs to. Nullable for backward-compatibility with
  // the pre-season-model data; backfilled to Season 7 and always set going forward.
  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id])

  drivers          Driver[]
  results          RaceResult[]
  constructorScores ConstructorRaceScore[]
  seatOffers       SeatOffer[]
}

model Driver {
  id          String   @id
  name        String
  discordName String
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id])
  // Which season this driver entry belongs to (backfilled to Season 7).
  seasonId    String?
  season      Season?  @relation(fields: [seasonId], references: [id])
  tier        Int // 0/1/2
  isActive    Boolean  @default(true)
  // Linked Discord account id (set on first Discord login) -> forgery-proof RSVP
  discordUserId String? @unique
  // Profile picture: admin-set URL takes priority, else the Discord avatar URL
  // captured on first Discord login (see discordAuth.js).
  photoUrl      String?
  discordAvatar String?
  // Self-selected nationality (ISO 3166-1 alpha-2, lowercase), set by the driver
  // on their profile page after Discord login. Takes priority over the static
  // roster baseline in the frontend's driverCountries.js.
  country       String?
  // Self-service profile extras, edited by the driver on /profile after Discord
  // login: a short "about me" blurb and an optional racing number (0-999).
  bio           String?
  number        Int?
  // Per-driver social links, edited on /profile. JSON object keyed by platform
  // (twitch/youtube/instagram/tiktok/x) -> full URL; null/absent when unset.
  socials       String?
  // Which of the six headline stat tiles the driver shows on their public
  // profile (JSON array of tile keys; null = all). Managed via raw SQL
  // (ensureAppSchema + routes/me.js) so it's writable with the dev server up.
  profileTiles  String?
  // How the profile picture sits on the driver rating card, self-service on
  // /profile: JSON {"x":0-100,"y":0-100,"z":1-3} (focal point % + zoom); null =
  // the default framing. Raw SQL for the same reason as profileTiles.
  cardPhotoPos  String?
  // Special league role, shown on the rating card and profile: null = regular
  // driver, 'safety' = safety car driver. Managed via raw SQL (ensureAppSchema),
  // migration driver_role.
  role          String?
  // Admin-set: remove this (deactivated) driver from the public driver
  // standings entirely. Race results and constructor points stay untouched;
  // reactivating clears it. Managed via raw SQL (ensureAppSchema), migration
  // driver_hide_from_standings.
  hideFromStandings Boolean @default(false)
  results     RaceResult[]
  rsvps       RaceRsvp[]
  // Driver Market: seats this driver has offered, seats this (reserve) driver
  // was chosen to fill, and the offers this (reserve) driver is interested in.
  seatOffersOffered SeatOffer[]    @relation("SeatOfferedBy")
  seatOffersFilled  SeatOffer[]    @relation("SeatFilledBy")
  seatInterests     SeatInterest[]
  createdAt   DateTime @default(now())
}

model Race {
  id          String       @id @default(cuid())
  // Round number within its season (unique per season, so each season can start
  // again at round 1). Null for non-championship entries (SPECIAL/TRAINING).
  number      Int?
  // What kind of entry this is (migration race_type): CHAMPIONSHIP (scored
  // round), TRAINING (practice session — not scored, no round number, but RSVP
  // works for session planning) or SPECIAL (special event). Managed via raw
  // SQL (ensureAppSchema + lib/raceTypes.js).
  type        String       @default("CHAMPIONSHIP")
  // DEPRECATED, kept in sync as a derived flag: true for every non-CHAMPIONSHIP
  // type. All scoring/round-numbering reads still filter on it, which is
  // exactly why TRAINING rows carry it too — they must never score.
  isSpecialEvent Boolean   @default(false)
  // Which season this race belongs to (backfilled to Season 7).
  seasonId    String?
  season      Season?      @relation(fields: [seasonId], references: [id])
  track       String
  date        DateTime?
  isCompleted Boolean      @default(false)
  capacity    Int          @default(40) // grid size (Apollo "Accepted (n/40)")
  info        String? // optional event details (rules, mods, …) — Discord post + site
  // Session format for the announcement post and the site's upcoming-race
  // panels: qualifying length in minutes, race distance in laps. Optional.
  // Managed via raw SQL (ensureAppSchema) like driverOfTheDay* below.
  qualiMinutes Int?
  raceLaps     Int?
  // Admin-picked "Driver of the Day" for this race (a driver id). Shown as a
  // fan-favourite fact on the results view. null = not chosen. Managed via raw
  // SQL (ensureAppSchema) so it's writable while the dev server holds the client.
  driverOfTheDayId String?
  // Who made the Driver of the Day pick (the league's streamer decides each
  // round). Free text, shown under the pick on the results view.
  driverOfTheDayBy String?
  // Discord webhook message id for the live RSVP/event post (Apollo-style).
  discordMessageId String?
  results     RaceResult[]
  constructorScores ConstructorRaceScore[]
  rsvps       RaceRsvp[]
  seatOffers  SeatOffer[]

  @@unique([seasonId, number])
}

// Per-race attendance (replaces Apollo): a driver's status for an upcoming race.
model RaceRsvp {
  id        String   @id @default(cuid())
  raceId    String
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver   @relation(fields: [driverId], references: [id])
  status    String // ACCEPTED / DECLINED / TENTATIVE
  updatedAt DateTime @updatedAt

  @@unique([raceId, driverId])
}

// ---------------------------------------------------------------------------
// Driver Market. A full-time driver who can't attend offers their seat for an
// upcoming race; reserve drivers express interest; the offering driver (or an
// admin) picks who fills it. The confirmed reserve pre-fills the result import
// (subForTeam) and shows in the per-team race lineup. Interest stays open even
// after a seat is filled, so an admin can swap in a different reserve later.
model SeatOffer {
  id         String   @id @default(cuid())
  raceId     String
  race       Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  // The full-time driver giving up their seat, and the team/seat on offer (the
  // offering driver's own team at the time of the offer).
  driverId   String
  driver     Driver   @relation("SeatOfferedBy", fields: [driverId], references: [id])
  teamId     String
  team       Team     @relation(fields: [teamId], references: [id])
  status     String   @default("OPEN") // OPEN / FILLED / CANCELLED
  // The reserve chosen to fill the seat (null while OPEN / CANCELLED).
  filledById String?
  filledBy   Driver?  @relation("SeatFilledBy", fields: [filledById], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  interests  SeatInterest[]

  @@unique([raceId, driverId])
}

model SeatInterest {
  id        String    @id @default(cuid())
  offerId   String
  offer     SeatOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  driverId  String
  driver    Driver    @relation(fields: [driverId], references: [id])
  createdAt DateTime  @default(now())

  @@unique([offerId, driverId])
}

model RaceResult {
  id               String  @id @default(cuid())
  raceId           String
  race             Race    @relation(fields: [raceId], references: [id], onDelete: Cascade)
  driverId         String
  driver           Driver  @relation(fields: [driverId], references: [id])
  position         Int? // null = DNS / historical points-only result
  points           Int? // explicit points (historical). null => compute from position+status
  status           String  @default("FINISHED") // FINISHED/DNS/DNF/DSQ
  subForTeamId     String? // Reserve drives for this team
  subForTeam       Team?   @relation(fields: [subForTeamId], references: [id])
  // DEPRECATED: the old "penalty in places" model. Replaced by penaltySeconds
  // (time penalties). Kept as an unused column so the migration stays additive;
  // nothing reads or writes it any more.
  penaltyPositions Int     @default(0)
  // Steward time penalty in SECONDS (e.g. 5 or 10), added to totalTimeMs and the
  // field re-sorted by adjusted total time. 0 = none. Needs totalTimeMs to apply.
  penaltySeconds   Int     @default(0)
  // Real finishing-order metadata from the AC race JSON (for driver profiles).
  // grid/bestLap only enrich profiles; totalTimeMs is also used to apply time
  // penalties (re-sort the field by race time + penalty seconds).
  grid             Int? // starting grid position
  bestLapMs        Int? // best lap in milliseconds
  totalTimeMs      Int? // total race time in milliseconds (from AC `TotalTime`)
  // Car-to-car contacts this driver's car registered in the race (from the AC
  // result `Events`, COLLISION_WITH_CAR above a minimum impact speed). Feeds the
  // "Awareness/cleanliness" driver rating. null = not yet imported for this round.
  contacts         Int?
  // Extra telemetry distilled from the AC race JSON at import/backfill time (see
  // services/telemetryExtractor.js). All nullable; null = not imported yet.
  // These are written via raw SQL (like `contacts`) so they survive even before
  // the generated client is refreshed — kept in sync with lib/ensureSchema.js.
  envContacts        Int?  // wall / off-track collisions ("crashes")
  cuts               Int?  // sum of per-lap track cuts / off-tracks
  overtakes          Int?  // estimated on-track passes (heuristic)
  lapsLed            Int?  // laps led (leader at S/F line each lap; heuristic)
  laps               Int?  // laps completed
  cleanLaps          Int?  // laps within 10s of the driver's own best that race
  consistencyMs      Float? // stdev of clean lap times, ms (null under 3 clean laps)
  consistencyPct     Float? // simresults-style consistency % (avg racing lap vs best lap)
  gamePenalties      Int?  // count of in-game (AC) penalties issued
  gamePenaltySeconds Float? // total in-game penalty seconds

  @@unique([raceId, driverId])
}

// Per-race constructor totals (verified historical + computed at import time)
model ConstructorRaceScore {
  id     String @id @default(cuid())
  raceId String
  race   Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])
  tier   Int // 1 or 2 (which standings table this belongs to)
  points Int    @default(0)

  @@unique([raceId, teamId, tier])
}

model DriverSignup {
  id            String   @id @default(cuid())
  discordName   String
  preferredTeam String?
  experience    String?
  notes         String?
  status        String   @default("PENDING") // PENDING/APPROVED/REJECTED
  createdAt     DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// One row per Discord account that has ever logged in on the site — including
// people the name-matcher could NOT link to a Driver. Powers the admin
// "Members" tab: see who's registered, link them to a roster driver by hand,
// and ban accounts (a banned account can't log in and existing sessions stop
// working). Like Download, this table is managed via raw SQL (the running dev
// server locks the generated Prisma client on Windows) — see
// backend/src/lib/members.js, which must be kept in sync with this model.
model MemberAccount {
  discordId    String   @id
  username     String // discord username (login name)
  displayName  String? // discord global display name
  avatarUrl    String?
  banned       Boolean  @default(false)
  banReason    String?
  firstLoginAt DateTime @default(now())
  lastLoginAt  DateTime @default(now())
  loginCount   Int      @default(1)
  // When this member last opened the notification bell — everything newer
  // counts as unread (raw-SQL column, migration notifications).
  notificationsSeenAt DateTime?
}

// In-site notifications behind the nav-bar bell. recipientId null = broadcast
// every member sees; a discordId = personal (e.g. "you got the seat").
// dedupeKey (unique) makes event writes idempotent, so re-saving a race's
// results or re-checking race-day reminders can never post twice. Managed via
// raw SQL like MemberAccount — see backend/src/lib/notifications.js, which
// must be kept in sync with this model.
model Notification {
  id          String   @id
  type        String // RESULTS | REMINDER | DOWNLOAD | MARKET (icon key in the frontend)
  title       String
  body        String?
  link        String? // frontend route the entry navigates to
  recipientId String? // MemberAccount.discordId, or null for broadcast
  dedupeKey   String?  @unique
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

// Member-only download catalogue (self-hosted Assetto Corsa resources: tracks,
// safety car, CSP, Real Penalty, the F1 car, replays…). The large binaries live
// on the host's disk under backend/downloads/; this row only holds the metadata
// and the on-disk file name (or an external link). Currently created/managed via
// raw SQL (the running dev server locks the generated Prisma client on Windows),
// so this model is kept in sync by hand — see backend/src/lib/downloads.js.
model Download {
  id          String   @id @default(cuid())
  title       String
  category    String
  folderId    String?
  description String?
  version     String?
  installNote String?
  fileName    String?
  externalUrl String?
  sortOrder   Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Admin-created folders that group the downloads on the public page (e.g.
// "Tracks", "Cars", one folder per event...). Managed via raw SQL like the
// Download table itself (see ensureDownloadTables in lib/downloads.js);
// deleting a folder unfiles its downloads instead of deleting them.
model DownloadFolder {
  id          String  @id @default(cuid())
  name        String
  description String?
  sortOrder   Int     @default(0)
}

// Cross-season identity. Driver rows are per-season (a person racing in three
// seasons has three Driver rows); this table groups those rows under one shared
// personId so career stats aggregate and archive tables can show the person's
// current name with a "raced as <old name>" note. Managed via raw SQL (the
// running dev server locks the generated client on Windows) — see
// backend/src/lib/persons.js, which must be kept in sync with this model.
model PersonLink {
  driverId  String   @id
  personId  String
  createdAt DateTime @default(now())

  @@index([personId])
}
