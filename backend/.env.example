# SQLite database file (no install needed)
DATABASE_URL="file:./dev.db"

# Secret used to sign admin JWTs (change this in production)
JWT_SECRET="change-me-to-a-long-random-string"

# Port the API listens on
PORT=4000

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGIN="http://localhost:5173"

# --- Discord login (OPTIONAL) ---------------------------------------------
# Leave blank to disable Discord login (the site falls back to picking a driver
# from a dropdown). To enable: create an app at https://discord.com/developers,
# add an OAuth2 redirect of exactly DISCORD_REDIRECT_URI, then fill these in.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_REDIRECT_URI="http://localhost:5173/auth/discord/callback"
